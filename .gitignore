# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# capacitor / xcode noise
ios/App/Pods/
ios/App/App.xcodeproj/xcuserdata/
ios/App/App.xcworkspace/xcuserdata/
ios/App/App.xcodeproj/project.xcworkspace/xcuserdata/
android/.gradle/
android/app/build/
android/build/
android/local.properties

# clerk configuration (can include secrets)
/.clerk/

# Python agent
agent/venv/
agent/.venv/
agent/__pycache__/
agent/*.pyc
agent/.env
agent/*.json
